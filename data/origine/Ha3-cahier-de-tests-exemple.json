          "id": "EF-SYS-042",
          "title": "Afficher la reponse en streaming",
          "description": "Le systeme doit afficher la reponse de Claude en temps reel avec mise a jour progressive du texte.",
          "priority": "must",
          "steps": [
            "Lancer une generation",
            "Observer l'affichage en temps reel",
            "Verifier le curseur/spinner de generation",
            "Verifier l'auto-scroll",
            "Copier la reponse finale"
          ],
          "expectedResults": [
            "Texte apparait progressivement",
            "Latence moins de 100ms",
            "Scroll automatique",
            "Reponse copiable"
          ]
        },
        {
