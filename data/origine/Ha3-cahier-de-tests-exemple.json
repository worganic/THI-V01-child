      "section": 4,
      "tests": [
        {
          "id": "EF-SYS-031",
          "title": "Afficher une question a la fois",
          "description": "Le systeme doit afficher une seule question a la fois avec son label, description d'aide et barre de progression.",
          "priority": "must",
          "steps": [
