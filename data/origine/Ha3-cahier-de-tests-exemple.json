  "categories": [
    {
      "id": "templates",
      "name": "Gestion des Templates",
      "section": 1,
      "tests": [
        {
          "id": "EF-SYS-001",
          "title": "55Afficher la liste des templates",
          "description": "Le systeme doit afficher une grille de toutes les templates disponibles avec leur icone, nom, description courte, nombre de phases et tags.",
          "priority": "must",
          "objective": "Valider que toutes les templates du dossier structure/ sont correctement chargees et affichees dans une grille responsive.",
          "references": [
            "EU-01 : Decouvrir les templates disponibles",
            "BM-01 : Simplifier la creation de projets",
            "docs/Bg0-Exigences_Fonctionnelles_Structurees.md"
          ],
          "preconditions": [
            "Serveur backend demarre",
            "Au moins 1 template presente dans structure/",
            "Navigateur moderne (Chrome, Firefox, Edge)"
          ],
          "steps": [
            "Ouvrir la page d'accueil de l'application",
            "Verifier que la section \"Templates disponibles\" s'affiche",
            "Compter le nombre de templates affichees",
            "Pour chaque template, verifier la presence de: icone, nom, description, nombre de phases, tags",
            "Redimensionner la fenetre pour tester le responsive"
          ],
          "expectedResults": [
            "Toutes les templates sont listees",
            "Chaque carte affiche: icone, nom, description, phases_count, tags",
            "Grille responsive (1-4 colonnes selon largeur)",
            "Clic sur template affiche les details"
          ]
        },
        {
          "id": "EF-SYS-002",
          "title": "Afficher les details d'une template",
          "description": "Le systeme doit afficher une modale avec tous les details de la template selectionnee.",
          "priority": "must",
          "steps": [
            "Cliquer sur une carte template",
            "Verifier l'ouverture de la modale",
            "Verifier la presence de: nom complet, description, liste des phases, duree estimee",
            "Verifier le bouton \"Utiliser cette template\"",
            "Fermer la modale avec X ou clic exterieur"
          ],
          "expectedResults": [
            "Modale s'ouvre avec animation fluide",
            "Tous les details sont affiches",
            "Bouton \"Utiliser\" lance la creation",
            "Modale se ferme correctement"
          ]
        },
        {
          "id": "EF-SYS-003",
          "title": "Charger les phases d'une template",
          "description": "Le systeme doit charger et indexer toutes les phases d'une template depuis le dossier _phases/.",
          "priority": "must",
          "steps": [
            "Creer un projet depuis une template",
            "Verifier que les phases sont chargees dans le bon ordre",
            "Verifier les attributs de chaque phase (id, name, description, type, order, icon)",
            "Verifier qu'aucune phase n'est dupliquee"
          ],
          "expectedResults": [
            "Phases chargees dans l'ordre numerique",
            "Tous les attributs presents",
            "Pas de duplication",
            "Phases required identifiees"
          ]
        }
      ]
    },
    {
      "id": "projets",
      "name": "Gestion des Projets",
      "section": 2,
      "tests": [
        {
          "id": "EF-SYS-010",
          "title": "Creer un nouveau projet",
          "description": "Le systeme doit creer un nouveau projet avec un ID unique, enregistrer ses metadonnees et initialiser la structure de dossiers.",
          "priority": "must",
          "steps": [
            "Cliquer sur \"Nouveau projet\"",
            "Remplir le nom du projet",
            "Selectionner une template",
            "Valider la creation",
            "Verifier la redirection vers le projet",
            "Verifier les fichiers crees (project.json, history.json)"
          ],
          "expectedResults": [
            "ID unique genere",
            "project.json et history.json crees",
            "Statut \"in_progress\", completion 0%",
            "Timestamps created_at et updated_at corrects",
            "Redirection vers questionnaire phase 1"
          ]
        },
        {
          "id": "EF-SYS-011",
          "title": "Afficher la liste des projets",
          "description": "Le systeme doit afficher la liste de tous les projets avec leur progression, statut et derniere modification.",
          "priority": "must",
          "steps": [
            "Acceder a la page d'accueil",
            "Verifier la section \"Mes projets\"",
            "Verifier les informations de chaque projet",
            "Tester le tri par date et progression"
          ],
          "expectedResults": [
            "Tous les projets listes",
            "Nom, template, %, phase actuelle affiches",
            "Tri fonctionnel",
            "Projets termines identifies visuellement"
          ]
        },
        {
          "id": "EF-SYS-015",
          "title": "Calculer la progression globale",
          "description": "Le systeme doit calculer automatiquement le pourcentage de progression du projet.",
          "priority": "must",
          "steps": [
            "Creer un nouveau projet (0%)",
            "Repondre a quelques questions",
            "Verifier la mise a jour de la progression",
            "Completer une phase entiere",
            "Verifier la progression finale (100%)"
          ],
          "expectedResults": [
            "Projet vide = 0%",
            "Progression mise a jour en temps reel",
            "Projet termine = 100%",
            "Affichage sur carte et page projet"
          ]
        }
      ]
    },
