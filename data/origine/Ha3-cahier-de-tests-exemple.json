            "Utiliser le bouton \"Suivant\"",
            "Utiliser le bouton \"Precedent\"",
            "Verifier l'URL de la page",
            "Verifier que les reponses sont conservees"
          ],
          "expectedResults": [
            "Navigation instantanee",
            "Boutons desactives aux limites",
            "URL mise a jour",
            "Reponses conservees"
          ]
        }
      ]
    },
