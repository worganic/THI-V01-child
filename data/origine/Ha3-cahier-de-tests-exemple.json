            "Label et aide lisibles",
            "Progression correcte",
            "Animations fluides"
          ]
        },
        {
          "id": "EF-SYS-032",
          "title": "Supporter les differents types de questions",
          "description": "Le systeme doit supporter 10 types de questions: text, textarea, number, date, select, checkbox, radio, boolean, range, file.",
          "priority": "must",
          "steps": [
            "Tester un champ text (saisie libre)",
            "Tester un champ textarea (texte long)",
            "Tester un champ number (validation numerique)",
            "Tester un champ date (datepicker)",
            "Tester un champ select (liste deroulante)",
            "Tester checkbox et radio",
            "Tester range (slider)",
            "Tester file (upload)"
          ],
          "expectedResults": [
            "Chaque type affiche le bon composant",
            "Validations appropriees",
            "Options select/checkbox/radio correctes",
            "Upload fichiers fonctionnel"
          ]
        },
        {
          "id": "EF-SYS-033",
          "title": "Sauvegarder la reponse a une question",
          "description": "Le systeme doit sauvegarder automatiquement chaque reponse dans le fichier JSON du projet.",
          "priority": "must",
          "steps": [
            "Saisir une reponse a une question",
            "Verifier la notification de sauvegarde",
            "Quitter et revenir au projet",
            "Verifier que la reponse est restauree",
            "Verifier le timestamp answered_at"
          ],
          "expectedResults": [
            "Sauvegarde en moins de 1 seconde",
            "Timestamp enregistre",
            "Reponse persistante",
            "Aucune reponse perdue"
          ]
        }
      ]
    },
